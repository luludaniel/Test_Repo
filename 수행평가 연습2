#include <stdio.h> //표준라이브러리를 선언했어요. 이 헤더파일애 함수와 변수가 정의되어 있어요.

int main() //c언어에서가장 기본이되는 함수여서 프로그램의 시작과 마무리를 해요   {
    
    
    int i;  //
    int sum = 0; 
    for (i = 1; i < 10; i++) {
        sum = sum + i;
    }

    printf("1부터 10까지의 합: %d\n", sum);
    if (sum % 2 == 0) { 
        printf('결과는 짝수입니다.\n');
    } else {
        printf("결과는 홀수입니다.\n")
    }

    return 0;
}
