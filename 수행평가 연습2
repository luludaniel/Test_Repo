#include <stdio.h>

int main() {
    
    
    int i; // 반복용 변수
    int sum = 0; // i ~ 10까지 더한 값
    for (i = 1; i < 10; i++) {
        sum = sum + i; // i ~ 10까지 더함
    }

    printf("1부터 10까지의 합: %d\n", sum); // sum 출력
    if (sum % 2 == 0) {  // sum의 짝수 여부 판단
        printf("결과는 짝수입니다.\n"); // 짝수 여부 출력
    } else {
        printf("결과는 홀수입니다.\n"); //짝수 여부 출력
    }

    return 0;
}
