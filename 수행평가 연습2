#include <stdio.h>    //stdio.h불러옴

int main() {          //코드 시작
    
    
    int i;            //변수i 선언
    int sum = 0;         //변수 sum을 선언하며 0할당
    for (i = 1; i < 10; i++) {           //1부터 10미만까지 i의 값이 1씩 증가하며 아랫내용 반복
        sum = sum + i;                //기존의 sum에 i를 더한 만큼의 값을 sum으로 저장
    }

    printf("1부터 10까지의 합: %d\n", sum);  //"1부터 10까지의 합: %d"에서 %d자리에 sum을 넣은 문장을 출력후 줄 바꿈
    if (sum % 2 == 0) {                     //sum을 2로 나눈 나머지가 0이면 아래 코드 실행
        printf("결과는 짝수입니다.\n");        //"결과는 짝수입니다." 출력 후 줄 바꿈
    } else {                                //if문의 조건을 만족하지 못하면 아래 코드 실행
        printf("결과는 홀수입니다.\n");        //"결과는 홀수입니다." 출력 후 줄 바꿈
    }

    return 0;                                //코드 종료
}
