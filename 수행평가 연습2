#include <stdio.h> // 표준 라이브러리 선언

int main() { // 프로그램의 시작 main() 함수
    
    
    int i; // 반복문에서 사용할 변수 i 선언
    int sum = 0; // sum값 0으로 초기화
    for (i = 1; i <= 10; i++) { // i가 1부터 10이 될 떄까지 1씩 증가시키며 반복
        sum = sum + i; // sum값에 i를 더한 것을 저장
    }

    printf("1부터 10까지의 합: %d\n", sum); // sum값 출력
    if (sum % 2 == 0) { 
        printf("결과는 짝수입니다.\n"); // sum 값을 나누었을 때 나머지가 0이면 짝수 결과 출력
    } else {
        printf("결과는 홀수입니다.\n"); // sum값을 나누었을 때 나머지가 0이 아니면 홀수 결과 출력
    }

    return 0; // 프로그램 종료
}
