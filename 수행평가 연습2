#include <stdio.h>

int main() {                                                   //main 함수
    
    
    int i;
    int sum = 0; 
    for (i = 1; i < 10; i++) {
        sum = sum + i;
    }

    printf("1부터 10까지의 합: %d\n", sum);
    if (sum % 2 == 0) { 
        printf('결과는 짝수입니다.\n');
    } else {
        printf("결과는 홀수입니다.\n"); // ; 빠짐
    }

    return 0;                                               // 0 반환
}
