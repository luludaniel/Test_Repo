#include <stdio.h>

int main() {
    
    
    int i; // 더할 수
    int sum = 0; // 합
    for (i = 1; i <= 10; i++) { // 1부터 10까지 더한 것을 sum에 저장
        sum = sum + i;
    }

    printf("1부터 10까지의 합: %d\n", sum); // sum 출력
    if (sum % 2 == 0) { // sum이 짝수면 출력
        printf("결과는 짝수입니다.\n");
    } else { // sum이 홀수면 출력
        printf("결과는 홀수입니다.\n");
    }

    return 0;
}
