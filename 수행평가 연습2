#include <stdio.h> //헤더파일

int main() {
    
    
    int i; // i 인트값 생성
    int sum = 0; //sum 인트값 생성 및 0으로 초기화
    for (i = 1; i <= 10; i++) { //i가 0부터 10까지 1씩 더하며 반복
        sum = sum + i; // sum 값에 i 를 더한것을 다시 저장
    }

    printf("1부터 10까지의 합: %d\n", sum); // sum값 출력
    if (sum % 2 == 0) {  // sum값의 짝수/홀수 판단 및 출력
        printf("결과는 짝수입니다.\n");
    } else {
        printf("결과는 홀수입니다.\n");
    }

    return 0;
}
