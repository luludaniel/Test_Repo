#include <stdio.h>

int main() {                                               //main 함수선언
    int dan = 5;                                           // dan 변수 선언
    int i;                                                 // i 선언

    for (i = 0; i < 9; i++) {                             
        printf("%d * %d = %d\n", dan, i, dan * i); 
    }

    return 0;                                             //0반환
}
