#include <stdio.h>   //stdio.h 불러오기

int main() {        //코드 시작
    int dan = 5;     //변수 dan에 5할당
    int i;            //변수 i 선언

    for (i = 1; i <= 9; i++) {       
        printf("%d * %d = %d\n", dan, i, dan * i);
    }                //i가 0부터 9미만 까지 1씩 증가하며 printf("%d * %d = %d\n", dan, i, dan * i) 실행 %d에 대응하는 정수가 들어와 "%d * %d = %d"출력하고 행 바꿈
                        //끝에 ;이 없어 추가 구구단은 일반적으로 1부터 9까지 곱하므로 범위 수정
    return 0;            //코드 끝마침
}
