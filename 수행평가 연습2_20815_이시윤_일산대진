#include <stdio.h>// 표준 입출력 라이브러리를 포함하는 부분입니다.

int main() {// main 함수의 시작입니다.
    
    
    int i;// i라는 변수를 선언합니다.
    int sum = 0; // sum이라는 변수를 선언하고 0으로 초기화합니다.
    for (i = 1; i <= 10; i++) {// for문이 시작되는 부분입니다.
        sum = sum + i;// sum에 i를 더하는 부분입니다.
    }

    printf("1부터 10까지의 합: %d\n", sum);// 결과를 출력하는 부분입니다.
    if (sum % 2 == 0) { // sum이 짝수인지 확인하는 조건문입니다.
        printf("결과는 짝수입니다.\n");// 결과가 짝수일 때 출력하는 부분입니다.
    } else {// sum이 홀수일 때 실행되는 부분입니다.
        printf("결과는 홀수입니다.\n");// 결과가 홀수일 때 출력하는 부분입니다.
    }

    return 0;// main 함수가 정상적으로 종료되었음을 나타냅니다.
}// main 함수의 끝입니다.
